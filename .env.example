# OpenAI access
OPENAI_API_KEY=

# Choose `nvr` (default) or `ipc`.
VIGI_SOURCE=nvr

# NVR connection, required when VIGI_SOURCE=nvr.
VIGI_HOST=
VIGI_USERNAME=
VIGI_PASSWORD=
VIGI_PORT=20443
VIGI_VERIFY_SSL=true
# Set only when more than one online channel is available.
VIGI_CHANNEL_ID=
# main selects stream 1; minor selects stream 2.
VIGI_STREAM=main
# Optional absolute path when ffmpeg is not on PATH.
FFMPEG_PATH=

# Standalone IPC RTSP access, required when VIGI_SOURCE=ipc.
VIGI_IPC_HOST=
VIGI_IPC_USERNAME=
VIGI_IPC_PASSWORD=
# VIGI_IPC_VERIFY_TLS is an SDK/OpenAPI control-plane setting. The current
# Vision IPC workflow uses standard RTSP only and does not read this variable.
